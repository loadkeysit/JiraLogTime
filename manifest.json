{
  "manifest_version": 3,
  "name": "Jira Time Logger",
  "version": "1.3.3",
  "description": "Memorizza la pagina Jira attiva e consente di creare un log di tempo esterno in un file.",
  "permissions": [
    "storage",
    "downloads",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jira-time-logger@azienda.local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jira Time Logger",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": ["content_script.js"]
    }
  ]
}